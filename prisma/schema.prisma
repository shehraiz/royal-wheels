generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String   @id @default(cuid())
  phone     String   @unique
  email     String?
  name      String?
  createdAt DateTime @default(now())
  bookings      Booking[]
  photoRequests PhotoRequest[]
}

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
}

model Vehicle {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  category             String
  seats                Int
  pricePerDay          Int
  description          String
  transmission         String   @default("Automatic")
  fuelType             String   @default("Petrol")
  images               String   @default("[]")
  available            Boolean  @default(true)
  mileageLimitKmPerDay Int?
  extraKmCharge        Int?
  outOfCitySurcharge   Int?
  createdAt            DateTime @default(now())
  bookings      Booking[]
  photoRequests PhotoRequest[]
}

model Booking {
  id               String    @id @default(cuid())
  customerId       String
  vehicleId        String
  startDate        DateTime
  endDate          DateTime
  days             Int
  totalAmount      Int
  status           String    @default("PENDING")
  cnicImagePath    String?
  pickupLocation   String?
  notes            String?
  paymentMethod    String?
  paymentStatus    String    @default("UNPAID")
  paymentProofPath String?
  termsAcceptedAt  DateTime?
  createdAt        DateTime  @default(now())
  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
}

model PhotoRequest {
  id             String   @id @default(cuid())
  bookingId      String?
  vehicleId      String
  customerId     String
  status         String   @default("PENDING")
  responseImages String?
  createdAt      DateTime @default(now())
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model QuoteRequest {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  serviceType    String   // ESCORT | PROTOCOL | CONVOY
  date           DateTime
  pickupLocation String
  destination    String
  vehicleCount   Int?
  notes          String?
  status         String   @default("NEW") // NEW | CONTACTED | QUOTED | CLOSED
  createdAt      DateTime @default(now())
}
